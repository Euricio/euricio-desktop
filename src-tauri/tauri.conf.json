{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Euricio CRM",
  "version": "0.1.0",
  "identifier": "es.euricio.crm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Euricio CRM",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "copyright": "\u00a9 2026 Euricio",
    "category": "Business",
    "shortDescription": "Euricio CRM Desktop",
    "longDescription": "Plattform\u00fcbergreifende CRM Desktop-Anwendung f\u00fcr Euricio"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "euricio"
        ]
      }
    },
    "sql": {
      "preload": []
    }
  }
}